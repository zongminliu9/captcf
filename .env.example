# ─────────────────────────────────────────────────────────────────────────────
# CapTCF environment. Copy to `.env` and adjust. `pnpm setup` creates .env for you.
# The product runs fully with NO external/commercial API keys.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database ---
# A local PostgreSQL is managed for you by `pnpm db:up` (native, no Docker needed).
# It listens on port 5433 with a project-local data dir (.pgdata/) so it never
# collides with any system Postgres.
DATABASE_URL=postgres://captcf@localhost:5433/captcf
PGPORT=5433
PGDATABASE=captcf
PGUSER=captcf

# --- Auth ---
# 32+ char secret used to sign session cookies. `pnpm setup` generates a random one.
AUTH_SECRET=dev-only-insecure-secret-change-me-please-32chars

# --- Feature providers (ALL OPTIONAL) ---
# When absent, the product falls back to deterministic local behaviour and never
# shows a dead/disabled button.

# Optional: enable AI-graded writing/speaking feedback. Absent → local rubric only.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_FEEDBACK_PROVIDER=none   # none | openai | anthropic

# Optional: Stripe test keys enable real Checkout. Absent → dev entitlement simulator.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM=
PAYMENTS_PROVIDER=simulator  # simulator | stripe

# Optional: Google OAuth. Absent → the Google button is hidden (never dead).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: file storage adapter for speaking recordings. Default = local disk.
STORAGE_DRIVER=local         # local | s3 | r2 | supabase
STORAGE_LOCAL_DIR=.uploads

# Enable seeded demo accounts (development only — ignored when NODE_ENV=production)
ENABLE_DEMO_ACCOUNTS=true
