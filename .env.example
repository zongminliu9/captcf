# ─────────────────────────────────────────────────────────────────────────────
# CapTCF environment. Copy to `.env` and adjust. `pnpm setup` creates .env for you.
# The product runs fully with NO external/commercial API keys.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database ---
# A local PostgreSQL is managed for you by `pnpm db:up` (native, no Docker needed).
# It listens on port 5433 with a project-local data dir (.pgdata/) so it never
# collides with any system Postgres.
DATABASE_URL=postgres://captcf@localhost:5433/captcf
PGPORT=5433
PGDATABASE=captcf
PGUSER=captcf

# --- Auth ---
# 32+ char secret used to sign session cookies. `pnpm setup` generates a random one.
AUTH_SECRET=dev-only-insecure-secret-change-me-please-32chars

# --- Feature providers (ALL OPTIONAL) ---
# When absent, the product falls back to deterministic local behaviour and never
# shows a dead/disabled button.

# Optional: enable AI-graded writing/speaking feedback. Absent → local rubric only.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_FEEDBACK_PROVIDER=none   # none | openai | anthropic

# Payments. In the hosted Private Beta use `beta`: real checkout is disabled and no one can
# self-upgrade; invited testers get Premium via the admin "grant Beta access" control.
# `simulator` (dev only) grants Premium immediately. `stripe` + keys enables real Checkout.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PREMIUM=
PAYMENTS_PROVIDER=simulator  # simulator (dev) | beta (hosted beta) | stripe

# Optional: Google OAuth. Absent → the Google button is hidden (never dead).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: file storage adapter for speaking recordings. Default = local disk.
STORAGE_DRIVER=local         # local | s3 | r2 | supabase
STORAGE_LOCAL_DIR=.uploads

# Enable seeded demo accounts (development only — ignored when NODE_ENV=production)
ENABLE_DEMO_ACCOUNTS=true

# --- Beta (client-visible, inlined at build time) ---
# Show the "Private Beta" strip + feedback entry. Set to "false" to hide it.
NEXT_PUBLIC_BETA=true
# Show the demo-account credentials box on the login page. MUST be unset/"false" in the hosted
# beta so credentials are never displayed publicly. "true" only for local dev convenience.
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=true

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION / HOSTED BETA (see docs/DEPLOYMENT.md). Render sets most of these for you.
#   NODE_ENV=production
#   DATABASE_URL=<managed Postgres connection string>   (NOT a local/dev/test DB)
#   AUTH_SECRET=<32+ random chars>                        (openssl rand -hex 32)
#   APP_URL=<https URL>                                   (or leave unset on Render → RENDER_EXTERNAL_URL)
#   ENABLE_DEMO_ACCOUNTS=false
#   PAYMENTS_PROVIDER=beta
#   NEXT_PUBLIC_BETA=true
#   NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=false
# ─────────────────────────────────────────────────────────────────────────────
