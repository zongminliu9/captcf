{
  "name": "captcf",
  "version": "0.1.0",
  "private": true,
  "description": "CapTCF — an original TCF Canada intelligent exam-prep platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "start:prod": "tsx scripts/bootstrap.ts && next start -p ${PORT:-3000}",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "db:up": "tsx scripts/pg.ts up",
    "db:down": "tsx scripts/pg.ts down",
    "db:status": "tsx scripts/pg.ts status",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:seed": "tsx scripts/seed.ts",
    "content:ingest": "tsx scripts/content/ingest.ts",
    "content:ingest2": "tsx scripts/content/ingest-merge.ts",
    "content:validate": "tsx scripts/content/audit.ts",
    "content:audit": "tsx scripts/content/audit.ts --require-audio",
    "content:dedupe": "tsx scripts/content/dedupe.ts",
    "content:audio": "tsx scripts/content/audio.ts",
    "content:audio:qa": "tsx scripts/content/audio-qa.ts",
    "setup": "tsx scripts/setup.ts",
    "demo": "tsx scripts/demo.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm content:audit && pnpm content:audio:qa && pnpm build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9",
    "zod": "4.4.3",
    "bcryptjs": "3.0.3",
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0",
    "class-variance-authority": "0.7.1",
    "@radix-ui/react-dialog": "^1.1",
    "@radix-ui/react-dropdown-menu": "^2.1",
    "@radix-ui/react-slider": "^1.2",
    "@radix-ui/react-tabs": "^1.1",
    "@radix-ui/react-progress": "^1.1",
    "@radix-ui/react-slot": "^1.1",
    "@radix-ui/react-label": "^2.1",
    "@radix-ui/react-radio-group": "^1.2",
    "@radix-ui/react-toast": "^1.2",
    "lucide-react": "^0.469"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/bcryptjs": "^2.4",
    "@types/node": "^22.10",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "drizzle-kit": "0.31.10",
    "postcss": "8.5.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "4.1.10"
  }
}
